# =============================================================================
# NEDS CRM — production .env template (Hostinger Business shared hosting)
# Copy to `.env` ON THE SERVER and fill in real values. NEVER commit the real .env.
# Generate APP_KEY with: php artisan key:generate  (or `php artisan key:generate --show`)
# =============================================================================

APP_NAME="Niranjan Enterprises Digital Solutions"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://crm.talktonitesh.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=UTC

BCRYPT_ROUNDS=12

# --- Database (create in hPanel → MySQL; quote the password if it contains #) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=""

# --- Shared hosting drivers (no Redis / daemons) ---
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_SECURE_COOKIE=true
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

# --- Logging (keep production quiet; daily rotation) ---
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=warning

# --- Security policy ---
ENFORCE_TWO_FACTOR_ENROLLMENT=true

# --- Mail (use Hostinger SMTP or a transactional provider) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="crm@talktonitesh.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Public website lead-capture API shared secret ---
LEAD_CAPTURE_TOKEN=

# --- Nightly database backup ---
# DB_DUMP_BINARY: full path to mysqldump if it isn't on PATH (ask Hostinger support).
DB_DUMP_BINARY=mysqldump
BACKUP_NOTIFY_EMAIL=niranjan.enterprisespune@gmail.com

# --- AI (Anthropic/Claude) — only set AI_ENABLED=true when you want it live ---
AI_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
