# Copy this file to .env and fill in real values. Never commit .env.

# eSSL device, reached over the office LAN (confirmed reachable at this
# address/port by the existing "hitech" billing software).
DEVICE_IP=192.168.1.201
DEVICE_PORT=4370

# CRM ADMS webhook (same one the device itself tries and fails to reach
# over its own HTTPS push).
CRM_URL=https://crm.talktonitesh.com/iclock/cdata
DEVICE_SERIAL=NFZ8243301103

# How many trailing days of device punches to re-send each run. The CRM
# webhook is idempotent (keeps the earliest check-in / latest check-out per
# day), so re-sending the same punches every run is harmless — this is what
# makes the bridge self-healing across restarts/missed runs without needing
# any local sync-state file.
DAYS_BACK=3
