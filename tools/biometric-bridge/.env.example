# Copy this file to .env and fill in real values. Never commit .env.

# eSSL device, reached over the office LAN (confirmed reachable at this
# address/port by the existing "hitech" billing software).
DEVICE_IP=192.168.1.201
DEVICE_PORT=4370

# CRM ADMS webhook (same one the device itself tries and fails to reach
# over its own HTTPS push).
CRM_URL=https://crm.niranjanenterprises.co.in/iclock/cdata
DEVICE_SERIAL=NFZ8243301103

# How many trailing days of device punches to re-send each run. The CRM
# webhook is idempotent (keeps the earliest check-in / latest check-out per
# day), so re-sending the same punches every run is harmless — this is what
# makes the bridge self-healing across restarts/missed runs without needing
# any local sync-state file.
DAYS_BACK=3

# Used by check-manual-sync.mjs (the "Sync now" button on the CRM's
# Attendance page) — NOT the same thing as CRM_URL above, which is the
# device's own ADMS webhook path. This is the plain site root.
CRM_BASE_URL=https://crm.niranjanenterprises.co.in

# Shared secret for check-manual-sync.mjs's calls to
# /api/biometric-sync/pending and /complete. Must match BIOMETRIC_BRIDGE_TOKEN
# in the CRM's own .env — separate secret from DEVICE_SERIAL above, which
# authenticates the device's push, not this script's polling.
BIOMETRIC_BRIDGE_TOKEN=
