APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Shared secret for the public website lead-capture API (POST /api/leads).
LEAD_CAPTURE_TOKEN=

# nedsdrishti.in integration — client provisioning on deal won.
# DRISHTI_SERVICE_KEY must match the SERVICE_API_KEY set in the Drishti .env.
DRISHTI_API_URL=https://nedsdrishti.in
DRISHTI_SERVICE_KEY=

# socialmediadost.com integration — client provisioning on deal won.
# SMDOST_SERVICE_KEY must match the SMDOST_SERVICE_KEY set in the SMDost .env.
SMDOST_API_URL=https://socialmediadost.com
SMDOST_SERVICE_KEY=

# WhatsApp webhook shared secret (wadesk.in → CRM, inbound).
WHATSAPP_WEBHOOK_TOKEN=

# wadesk.in outbound replies (CRM staff reply → WhatsApp via wadesk.in).
# WADESK_SERVICE_KEY must match the WADESK_SERVICE_KEY set in wadesk.in's .env.
WADESK_API_URL=https://wadesk.in
WADESK_SERVICE_KEY=

# AI (Anthropic/Claude) — Phase 5. Off by default; flip AI_ENABLED=true and set
# the key to enable lead scoring, draft replies, and summaries.
AI_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Nightly database backup. DB_DUMP_BINARY: full path to mysqldump if not on PATH.
# BACKUP_NOTIFY_EMAIL: where the backup confirmation is sent (blank = no email).
DB_DUMP_BINARY=mysqldump
BACKUP_NOTIFY_EMAIL=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production (HTTPS) so the session cookie is only sent over SSL.
SESSION_SECURE_COOKIE=false
# Require admins & managers to set up TOTP 2FA before using the app (production).
ENFORCE_TWO_FACTOR_ENROLLMENT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
