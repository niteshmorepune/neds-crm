APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Shared secret for the public website lead-capture API (POST /api/leads).
LEAD_CAPTURE_TOKEN=

# nedsdrishti.in integration — client provisioning on deal won.
# DRISHTI_SERVICE_KEY must match the SERVICE_API_KEY set in the Drishti .env.
DRISHTI_API_URL=https://nedsdrishti.in
DRISHTI_SERVICE_KEY=

# socialmediadost.com integration — client provisioning on deal won.
# SMDOST_SERVICE_KEY must match the SMDOST_SERVICE_KEY set in the SMDost .env.
SMDOST_API_URL=https://socialmediadost.com
SMDOST_SERVICE_KEY=

# WhatsApp webhook shared secret (wadesk.in → CRM, inbound).
WHATSAPP_WEBHOOK_TOKEN=

# wadesk.in outbound replies (CRM staff reply → WhatsApp via wadesk.in).
# WADESK_SERVICE_KEY must match the WADESK_SERVICE_KEY set in wadesk.in's .env.
WADESK_API_URL=https://wadesk.in
WADESK_SERVICE_KEY=

# Meta (Facebook/Instagram) Lead Ads webhook. META_WEBHOOK_VERIFY_TOKEN is a
# value you choose yourself and enter when registering the webhook in the
# Meta App Dashboard. META_APP_SECRET is the App Secret from that same app
# (verifies X-Hub-Signature-256 on inbound events). META_PAGE_ACCESS_TOKEN
# authorizes fetching the actual submitted lead fields from the Graph API
# (Meta's webhook event only carries a leadgen_id, not the field data).
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_PAGE_ACCESS_TOKEN=
META_GRAPH_API_VERSION=v19.0

# eSSL biometric device ADMS push (GET+POST /api/iclock/cdata).
# Set this to the device serial number shown in its Command Center screen.
# Configure the device: Cloud Server → ADMS → Server Address = crm.niranjanenterprises.co.in, Port = 443, HTTPS = ON.
BIOMETRIC_DEVICE_SERIAL=

# Shared secret for the office-LAN bridge script's manual "Sync now" polling
# (tools/biometric-bridge/check-manual-sync.mjs) — GET/POST /api/biometric-sync/*.
# Separate from BIOMETRIC_DEVICE_SERIAL above, which authenticates the device
# itself, not the bridge script. Must match BIOMETRIC_BRIDGE_TOKEN in the
# bridge's own .env.
BIOMETRIC_BRIDGE_TOKEN=

# AI (Anthropic/Claude) — Phase 5. Off by default; flip AI_ENABLED=true and set
# the key to enable lead scoring, draft replies, and summaries.
AI_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Lead score at/above this triggers an immediate hot-lead bell notification.
AI_HOT_LEAD_THRESHOLD=70

# Nightly database backup. DB_DUMP_BINARY: full path to mysqldump if not on PATH.
# BACKUP_NOTIFY_EMAIL: where the backup confirmation is sent (blank = no email).
DB_DUMP_BINARY=mysqldump
BACKUP_NOTIFY_EMAIL=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Set to true in production (HTTPS) so the session cookie is only sent over SSL.
SESSION_SECURE_COOKIE=false
# Require admins & managers to set up TOTP 2FA before using the app (production).
ENFORCE_TWO_FACTOR_ENROLLMENT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
